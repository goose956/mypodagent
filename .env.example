# Core runtime (required in production)
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=sk-...
KIE_AI_API_KEY=...
PRINTFUL_API_TOKEN=...
STORAGE_DIR=/app/uploads

# Set after first Railway deploy
APP_URL=https://your-app.up.railway.app

# Optional (only needed if using admin creation route)
ADMIN_CREATION_KEY=replace-with-admin-creation-key
